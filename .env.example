# Database connection string (SQLite example: file:./dev.db)
DATABASE_URL=

# Secret key for signing JWT access/refresh tokens
JWT_SECRET=

# Access token lifetime (example: 15m)
JWT_EXPIRES_IN=

# Refresh token lifetime (example: 7d)
JWT_REFRESH_EXPIRES_IN=

# Port for local server
PORT=3000

# SMTP server host (Brevo example: smtp-relay.brevo.com)
SMTP_HOST=

# SMTP server port (usually 587 for TLS)
SMTP_PORT=

# SMTP login/username from your email provider
SMTP_AUTH_USER=

# SMTP password/key from your email provider
SMTP_AUTH_PASS=

# Verified sender email address used in "from"
SENDER_EMAIL=